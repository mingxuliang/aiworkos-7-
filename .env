# ==============================================================================
# QwenPaw Configuration File
# ==============================================================================
# Copy this file to .env and modify the values as needed.
#   cp .env.example .env
#
# The .env file is automatically loaded on startup (python-dotenv).
# DO NOT commit .env to version control — it contains secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Authentication Mode
# ------------------------------------------------------------------------------
# "legacy" — single-user auth via auth.json (default)
# "jwt"    — JWT + Redis + MySQL multi-user RBAC authentication
QWENPAW_AUTH_MODE=jwt
AIWORK_AUTH_MODE=jwt

# ------------------------------------------------------------------------------
# JWT Configuration (only used when AIWORK_AUTH_MODE=jwt)
# ------------------------------------------------------------------------------

# JWT signing secret. Leave empty to auto-generate and persist a secret key.
# For production, set a strong random string (e.g. openssl rand -hex 32).
QWENPAW_JWT_SECRET=2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi
AIWORK_JWT_SECRET=2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi

# JWT token expiration time in minutes (default: 1440 = 24 hours)
QWENPAW_JWT_EXPIRE_MINUTES=1440
AIWORK_JWT_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------------------
# MySQL Database (only used when QWENPAW_AUTH_MODE=jwt)
# ------------------------------------------------------------------------------

# SQLAlchemy async connection URL for MySQL.
# Format: mysql+aiomysql://<user>:<password>@<host>:<port>/<database>
# NOTE: If the password contains special characters (@, #, /, etc.),
#       they must be URL-encoded (e.g. @ -> %40, # -> %23, / -> %2F).
QWENPAW_JWT_DB_URL=mysql+aiomysql://root:Sdgh%402026%23Secure@101.36.143.21:3306/aiwork
AIWORK_JWT_DB_URL=mysql+aiomysql://root:Sdgh%402026%23Secure@101.36.143.21:3306/aiwork

# ------------------------------------------------------------------------------
# Redis (only used when QWENPAW_AUTH_MODE=jwt)
# ------------------------------------------------------------------------------

# Redis URL for session storage and token blacklisting.
# Format: redis://<host>:<port>/<db>
QWENPAW_REDIS_URL=redis://:Sdgh%402026%23Secure@101.36.143.21:6379/0
AIWORK_REDIS_URL=redis://:Sdgh%402026%23Secure@101.36.143.21:6379/0

# 开启OpenAPI文档
QWENPAW_OPENAPI_DOCS=true
AIWORK_OPENAPI_DOCS=true

# ------------------------------------------------------------------------------
# MinIO 对象存储（文件素材库 / 售前模板库）
# ------------------------------------------------------------------------------
# MinIO 服务地址 host:port（不含 http://）
AIWORK_MINIO_ENDPOINT=101.36.143.20:9000
# Access Key / Secret Key
AIWORK_MINIO_ACCESS_KEY=sdgh
AIWORK_MINIO_SECRET_KEY=sdgh@2026
# 存储桶名称
AIWORK_MINIO_BUCKET=aiwork-files
# 是否使用 HTTPS（生产环境建议 true）
AIWORK_MINIO_SECURE=false
# 分片上传阈值（字节），默认 10MB
AIWORK_MINIO_CHUNK_SIZE=10485760
# 预签名 URL 有效期（秒），默认 3600
AIWORK_MINIO_PRESIGNED_EXPIRES=3600
# 上传会话过期时间（秒），默认 86400
AIWORK_MINIO_SESSION_TTL=86400
# 售前模板最大文件大小（字节），默认 500MB
AIWORK_PRESALE_MAX_FILE_SIZE=524288000

# ------------------------------------------------------------------------------
# LLM 产出物存储桶（MinIO，与文件素材库共用同一套 endpoint/credentials）
# ------------------------------------------------------------------------------
# LLM output 专属桶，默认 aiwork-llm-output
AIWORK_LLM_OUTPUT_BUCKET=aiwork-llm-output

# ------------------------------------------------------------------------------
# RAG 知识库配置（pgvector + MinIO + 嵌入 API）
# ------------------------------------------------------------------------------
# 原始文件桶
AIWORK_RAG_ORIGINALS_BUCKET=aiwork-rag-originals
# 图片提取桶
AIWORK_RAG_IMAGE_BUCKET=aiwork-rag-images

# pgvector 向量数据库（PostgreSQL + asyncpg）
# 密码含特殊字符需 URL 编码，@ -> %40
AIWORK_PGVECTOR_DB_URL=postgresql+asyncpg://sdgh:sdgh%402026@101.36.143.20:5432/aiwork

# 嵌入向量模型 API
AIWORK_RAG_EMBEDDING_API_URL=https://api.siliconflow.cn/v1
AIWORK_RAG_EMBEDDING_API_KEY=sk-zltaqofunjyooupwptspuqwldgvzpfdscinsckliwrmxnzig

# RAG 摘要 / 重排 LLM API
AIWORK_RAG_LLM_API_URL=https://api.siliconflow.cn/v1
AIWORK_RAG_LLM_API_KEY=sk-zltaqofunjyooupwptspuqwldgvzpfdscinsckliwrmxnzig

# MinerU PDF 解析服务
AIWORK_MINERU_API_URL=http://101.36.143.22:8000

# RAG 最大上下文 token 数
AIWORK_RAG_MAX_TOTAL_CONTEXT=3000